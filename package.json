{
  "name": "qlaude",
  "version": "0.1.0-alpha.21",
  "description": "Claude Code wrapper with enhanced features",
  "author": "qlaude team",
  "license": "MIT",
  "type": "module",
  "main": "./dist/main.js",
  "bin": {
    "qlaude": "./dist/main.js",
    "qlaude-session-hook": "./dist/bin/session-hook.js",
    "qlaude-setup-hooks": "./dist/bin/setup-hooks.js",
    "qlaude-remove-hooks": "./dist/bin/remove-hooks.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "start": "node dist/main.js",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "node dist/bin/setup-hooks.js",
    "preuninstall": "node dist/bin/remove-hooks.js"
  },
  "keywords": [
    "claude",
    "cli",
    "ai",
    "automation",
    "queue",
    "pty"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@xterm/headless": "^6.0.0",
    "js-yaml": "^4.1.1",
    "node-pty": "^1.1.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "5.3",
    "vitest": "^2.1.9"
  }
}

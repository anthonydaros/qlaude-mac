{
  "name": "qlaude",
  "version": "0.2.2-alpha.0",
  "description": "Claude Code wrapper with enhanced features",
  "author": "qlaude team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/starsh2001/qlaude.git"
  },
  "homepage": "https://github.com/starsh2001/qlaude",
  "bugs": {
    "url": "https://github.com/starsh2001/qlaude/issues"
  },
  "type": "module",
  "main": "./dist/main.js",
  "bin": {
    "qlaude": "dist/main.js",
    "qlaude-session-hook": "dist/bin/session-hook.js",
    "qlaude-setup-hooks": "dist/bin/setup-hooks.js",
    "qlaude-remove-hooks": "dist/bin/remove-hooks.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "start": "node dist/main.js",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "node --input-type=module -e \"import { existsSync } from 'node:fs'; if (existsSync('dist/bin/setup-hooks.js')) await import('./dist/bin/setup-hooks.js');\"",
    "preuninstall": "node --input-type=module -e \"import { existsSync } from 'node:fs'; if (existsSync('dist/bin/remove-hooks.js')) await import('./dist/bin/remove-hooks.js');\""
  },
  "keywords": [
    "claude",
    "cli",
    "ai",
    "automation",
    "queue",
    "pty"
  ],
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@xterm/headless": "^6.0.0",
    "node-pty": "1.1.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.30",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.4",
    "globals": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7",
    "vitest": "^4.1.0"
  }
}

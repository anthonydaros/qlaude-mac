{
  "name": "qlaude",
  "version": "0.2.2-alpha.0",
  "description": "Claude Code wrapper with enhanced features",
  "author": "qlaude team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/starsh2001/qlaude.git"
  },
  "homepage": "https://github.com/starsh2001/qlaude",
  "bugs": {
    "url": "https://github.com/starsh2001/qlaude/issues"
  },
  "type": "module",
  "main": "./dist/main.js",
  "bin": {
    "qlaude": "dist/main.js",
    "qlaude-session-hook": "dist/bin/session-hook.js",
    "qlaude-setup-hooks": "dist/bin/setup-hooks.js",
    "qlaude-remove-hooks": "dist/bin/remove-hooks.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "start": "node dist/main.js",
    "dev": "tsup --watch",
    "dev:electron": "electron-vite dev",
    "build:electron": "electron-vite build",
    "package": "electron-vite build && electron-builder",
    "rebuild": "electron-rebuild -f -w node-pty",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "node dist/bin/setup-hooks.js",
    "preuninstall": "node dist/bin/remove-hooks.js"
  },
  "keywords": [
    "claude",
    "cli",
    "ai",
    "automation",
    "queue",
    "pty"
  ],
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^41.0.0",
    "node-pty": "1.1.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^20.19.30",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^2.1.9",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7",
    "vitest": "^2.1.9"
  }
}
